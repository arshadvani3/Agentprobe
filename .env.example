# ─── LLM Judge ────────────────────────────────────────────────────────────────
# Option A: Groq (recommended for cloud/production — free at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Option B: Local Ollama (used when GROQ_API_KEY is not set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/agentprobe
REDIS_URL=redis://localhost:6379

# ─── Storage ──────────────────────────────────────────────────────────────────
CHROMADB_PATH=./data/chromadb

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Leave empty to disable auth (dev mode). Set a secret string to enable.
AGENTPROBE_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
